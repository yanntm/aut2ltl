# Caches (match at any depth)
__pycache__/
*.pyc
*.pyo

# Editors
.idea/
.vscode/

# Build artifacts (editable install / sdist / wheel). No blanket `build/` — it is
# too wide for repo scope (it swallows the source package `sosl/sos/build/`).
*.egg-info/
dist/

# Scratch survey/test output. Persisted reference runs live in results/ and are
# committed; throwaway runs go to the root logs/ dir, which is the only ignored
# folder (no blanket *.csv ignore — committed CSVs need no re-include dance).
/logs/
*.log
