// sos2cayley gf_aa.sos --rename a=a,!a=b
digraph core_F1_gf_aa {
  rankdir=TB;
  ranksep=0.87; nodesep=0.55;
  node [shape=box, style=rounded, fontname="serif", margin="0.06,0.03"];
  edge [fontname="serif", fontsize=10, arrowsize=0.7];
  label="λ: a ↣ [a], b ↣ [b]\nP = { ([a·a],[a·a]) }";
  labelloc="b"; labeljust="c"; fontname="serif"; fontsize=11;

  a [label="[a]"];
  b [label="[b]"];
  aa [label="[a·a]"];
  ab [label="[a·b]"];
  ba [label="[b·a]"];

  { rank=same; a b; }
  { rank=same; aa ab ba; }

  a -> aa [label="[a],[a·a],\n[a·b]", weight=3];
  a -> ab [label="[b]", weight=3];
  a -> a [label="[b·a]", weight=1];
  b -> ba [label="[a],[b·a]", weight=3];
  b -> b [label="[b],[a·b]", weight=1];
  b -> aa [label="[a·a]", weight=1];
  aa -> aa [label="[a],[b],\n[a·a],\n[a·b],\n[b·a]", weight=1];
  ab -> a [label="[a],[b·a]", weight=1];
  ab -> ab [label="[b],[a·b]", weight=1];
  ab -> aa [label="[a·a]", weight=1];
  ba -> aa [label="[a],[a·a],\n[a·b]", weight=1];
  ba -> b [label="[b]", weight=1];
  ba -> ba [label="[b·a]", weight=1];
}
