// sos2cayley a_implies_xa.sos --rename a=a,!a=b
digraph a_implies_xa {
  rankdir=TB;
  ranksep=0.87; nodesep=0.55;
  node [shape=box, style=rounded, fontname="serif", margin="0.06,0.03"];
  edge [fontname="serif", fontsize=10, arrowsize=0.7];
  label="λ: a ↣ [a], b ↣ [b]\nP = { ([b],[b]), ([b],[a·a]), ([b],[a·b]), ([a·a],[b]), ([a·a],[a·a]), ([a·a],[a·b]) }";
  labelloc="b"; labeljust="c"; fontname="serif"; fontsize=11;

  a [label="[a]"];
  b [label="[b]"];
  aa [label="[a·a]"];
  ab [label="[a·b]"];

  { rank=same; a b; }
  { rank=same; aa ab; }

  a -> aa [label="[a],[a·a],\n[a·b]", weight=3];
  a -> ab [label="[b]", weight=3];
  b -> b [label="C", weight=1];
  aa -> aa [label="C", weight=1];
  ab -> ab [label="C", weight=1];
}
