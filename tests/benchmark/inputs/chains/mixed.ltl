# Alternating-operator chains (W/U, U/R)
# generated by tests/benchmark/patterns.py -- do not hand-edit

(a W (a & b))  # wu_mix2
(a W ((a & b) U (b | c)))  # wu_mix3
(a W ((a & b) U ((b | c) W (a & X b))))  # wu_mix4
(a U (a & b))  # ur_mix2
