# Until chains with X-laced arms (every other arm under X)
# generated by tests/benchmark/patterns.py -- do not hand-edit

(a U X (a & b))  # uchain_x2
(a U (X (a & b) U (b | c)))  # uchain_x3
(a U (X (a & b) U ((b | c) U X (a & X b))))  # uchain_x4
(a W X (a & b))  # wchain_x2
(a W (X (a & b) W (b | c)))  # wchain_x3
(a W (X (a & b) W ((b | c) W X (a & X b))))  # wchain_x4
